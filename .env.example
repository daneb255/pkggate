# pkggate Environment Configuration
# Copy this file to .env and adjust values for your environment

# Server binding
PKGGATE_HOST=0.0.0.0
PKGGATE_PORT=8080

# Upstream registries
PKGGATE_UPSTREAM_NPM=https://registry.npmjs.org

# OSV API and mirror configuration
PKGGATE_OSV_API=https://api.osv.dev/v1/query
PKGGATE_OSV_BUNDLE_NPM=https://storage.googleapis.com/osv-vulnerabilities/npm/all.zip
PKGGATE_OSV_BUNDLE_PYPI=https://storage.googleapis.com/osv-vulnerabilities/PyPI/all.zip

# Local mirror database
PKGGATE_MIRROR_DB=mirror.db
PKGGATE_MIRROR_ENABLED=true
PKGGATE_MIRROR_REFRESH_SECONDS=3600

# Fall back to live API for clean packages (good for fresh packages)
PKGGATE_LIVE_FALLBACK_ENABLED=false

# Policy and audit logging
PKGGATE_POLICY_FILE=config/policy.yaml
PKGGATE_AUDIT_LOG=audit.log

# PyPI proxy
PKGGATE_PYPI_ENABLED=true
PKGGATE_PYPI_UPSTREAM_SIMPLE=https://pypi.org/simple/
PKGGATE_PYPI_UPSTREAM_FILES=https://files.pythonhosted.org/
PKGGATE_PYPI_PUBLIC_BASE_URL=http://127.0.0.1:8080
PKGGATE_PYPI_VERIFY_INTEGRITY=true
PKGGATE_PYPI_MAX_BUFFER_BYTES=209715200

# Timeouts (seconds)
PKGGATE_UPSTREAM_TIMEOUT_SECONDS=30.0
PKGGATE_INTEL_TIMEOUT_SECONDS=5.0
